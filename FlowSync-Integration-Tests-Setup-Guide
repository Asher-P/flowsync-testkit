## Step 8: Write Your First Test

Create a test class that inherits from the base class:

**Create `Tests/HappyPathTests.cs`:**

```csharp
using Journey.Core.Messaging.Publishing.Entities;
using Journey.Orchestration.Configurations;
using Journey.Orchestration.Factories;
using Microsoft.Extensions.DependencyInjection;
using NUnit.Framework;
using YourService.IntegrationTests.Constants;
using YourService.IntegrationTests.Extensions;

namespace YourService.IntegrationTests.Tests;

/// <summary>
/// Happy path integration tests for your service
/// </summary>
public class HappyPathTests : IntegrationTestBase
{
    [Test, Category("P0")]
    public async Task Should_Process_Message_Successfully()
    {
        try
        {
            // ========================================
            // ARRANGE - Setup test data
            // ========================================
            
            // Create your input message
            var inputMessage = new YourInputDto
            {
                Id = Guid.NewGuid(),
                Name = "Test Message",
                Timestamp = DateTime.UtcNow
            };
            
            // Get the journey factory from DI
            var journeyFactory = ServiceProvider.GetRequiredService<IJourneyFactory>();
            
            // ========================================
            // CONFIGURE JOURNEY
            // ========================================
            
            // Create a journey step that:
            // 1. Produces to INPUT_TOPIC
            // 2. Consumes from OUTPUT_TOPIC_1
            // 3. Waits up to 30 seconds for 1 message
            var journey = await journeyFactory.CreateJourneyStepAsync(
                new JourneyConfiguration
                {
                    ProduceTo = TestConstants.INPUT_TOPIC,
                    ConsumeFrom = new[] { TestConstants.OUTPUT_TOPIC_1 },
                    ConsumingOptions = new ConsumingOptionsConfiguration
                    {
                        TimeOut = TimeSpan.FromSeconds(30),
                        MsgReceivedCount = 1,
                    }
                });
            
            // Small delay to ensure consumers are ready
            await Task.Delay(1000);
            
            // ========================================
            // ACT - Execute the journey
            // ========================================
            
            // Create message key (customize based on your partitioning strategy)
            var messageKey = $"{inputMessage.Id}";
            
            // Execute the journey - this will:
            // 1. Produce your message to INPUT_TOPIC
            // 2. Wait for response on OUTPUT_TOPIC_1
            // 3. Return the consumed messages
            // Note: Journey Framework automatically adds correlation_id to headers
            var waitForMessagesTask = await journey.ExecuteAsync(
                messageKey,
                inputMessage,
                new ProducingExtraData
                {
                    Headers = new Dictionary<string, string>
                    {
                        {"source", "integration-test"}
                    }
                });

            // Wait for the messages to be consumed
            var messages = await waitForMessagesTask.Task;

            // ========================================
            // ASSERT - Validate results
            // ========================================
            
            // Extract your output messages from the response
            var outputMessages = messages
                .SelectMany(r => r.Messages)
                .Where(mc => mc.Value is YourOutputDto)
                .Select(mc => (YourOutputDto)mc.Value)
                .ToList();
            
            // Validate that we received messages
            Assert.IsNotEmpty(outputMessages, "Should receive at least one output message");
            
            // Validate the output content
            var outputMessage = outputMessages.First();
            Assert.AreEqual(inputMessage.Id, outputMessage.Id, "Output ID should match input ID");
            Assert.IsNotNull(outputMessage.ProcessedAt, "ProcessedAt timestamp should be set");
            
            Console.WriteLine($"✅ Successfully processed message {inputMessage.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Test failed: {ex.Message}");
            throw;
        }
    }
    
    [Test, Category("P1")]
    public async Task Should_Handle_Invalid_Message_Gracefully()
    {
        try
        {
            // ========================================
            // ARRANGE
            // ========================================
            
            // Create an invalid input message
            var invalidMessage = new YourInputDto
            {
                Id = Guid.Empty,  // Invalid ID
                Name = null,      // Missing required field
            };
            
            var journeyFactory = ServiceProvider.GetRequiredService<IJourneyFactory>();
            
            // Configure journey to expect message on error topic
            var journey = await journeyFactory.CreateJourneyStepAsync(
                new JourneyConfiguration
                {
                    ProduceTo = TestConstants.INPUT_TOPIC,
                    ConsumeFrom = new[] { TestConstants.OUTPUT_TOPIC_2 },  // Error topic
                    ConsumingOptions = new ConsumingOptionsConfiguration
                    {
                        TimeOut = TimeSpan.FromSeconds(30),
                        MsgReceivedCount = 1,
                    }
                });
            
            await Task.Delay(1000);
            
            // ========================================
            // ACT
            // ========================================
            
            var messageKey = "invalid-message";
            var waitForMessagesTask = await journey.ExecuteAsync(
                messageKey,
                invalidMessage);

            var messages = await waitForMessagesTask.Task;

            // ========================================
            // ASSERT
            // ========================================
            
            var errorMessages = messages
                .SelectMany(r => r.Messages)
                .Where(mc => mc.Value is YourErrorDto)
                .Select(mc => (YourErrorDto)mc.Value)
                .ToList();
            
            Assert.IsNotEmpty(errorMessages, "Should receive error message");
            
            var errorMessage = errorMessages.First();
            Assert.IsNotNull(errorMessage.ErrorReason, "Error reason should be provided");
            
            Console.WriteLine($"✅ Invalid message handled correctly: {errorMessage.ErrorReason}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Test failed: {ex.Message}");
            throw;
        }
    }
}
```

### Understanding the Test Pattern

**1. Journey Configuration:**
```csharp
var journey = await journeyFactory.CreateJourneyStepAsync(
    new JourneyConfiguration
    {
        ProduceTo = TestConstants.INPUT_TOPIC,      // Where to send test message
        ConsumeFrom = new[] { TestConstants.OUTPUT_TOPIC_1 },  // Where to expect response
        ConsumingOptions = new ConsumingOptionsConfiguration
        {
            TimeOut = TimeSpan.FromSeconds(30),     // How long to wait
            MsgReceivedCount = 1,                   // How many messages to expect
        }
    });
```

**2. Message Execution:**
```csharp
// Note: Journey Framework automatically adds correlation_id to headers
var waitForMessagesTask = await journey.ExecuteAsync(
    messageKey,      // Kafka message key for partitioning
    inputMessage,    // Your message payload
    new ProducingExtraData  // Optional headers (correlation_id is added automatically)
    {
        Headers = new Dictionary<string, string>
        {
            {"source", "integration-test"}  // Add custom headers as needed
        }
    });
```

**3. Response Handling:**
```csharp
var messages = await waitForMessagesTask.Task;

// Extract typed messages from response
var outputMessages = messages
    .SelectMany(r => r.Messages)
    .Where(mc => mc.Value is YourOutputDto)
    .Select(mc => (YourOutputDto)mc.Value)
    .ToList();
```

