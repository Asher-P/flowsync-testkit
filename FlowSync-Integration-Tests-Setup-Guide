## Step 7: Create Test Base Class

Create an abstract test base class that handles Journey Framework setup and cleanup:

**Create `Tests/IntegrationTestBase.cs`:**

```csharp
using Confluent.Kafka;
using Confluent.Kafka.Admin;
using KafkaFlow;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using NUnit.Framework;
using YourService.IntegrationTests.Constants;
using YourService.IntegrationTests.Extensions;
using YourService.IntegrationTests.Models;

namespace YourService.IntegrationTests.Tests;

/// <summary>
/// Base class for all integration tests.
/// Handles Journey Framework initialization and Kafka consumer group cleanup.
/// </summary>
public abstract class IntegrationTestBase
{
    protected IConfigurationRoot Configuration { get; private set; }
    protected IServiceProvider ServiceProvider { get; private set; }
    
    /// <summary>
    /// Runs once before all tests in the test class.
    /// Initializes Journey Framework and cleans up consumer groups.
    /// </summary>
    [OneTimeSetUp]
    public async Task OneTimeSetUp()
    {
        await Setupjourney();
        await CleanupConsumerGroups();
    }
    
    /// <summary>
    /// Initialize the service provider and configuration
    /// </summary>
    private Task Setupjourney()
    {
        Console.WriteLine("Setting up Journey Framework...");
        var (serviceProvider, configuration) = IoCHelper.InitServiceProvider();
        ServiceProvider = serviceProvider;
        Configuration = configuration;
        Console.WriteLine("Journey Framework setup completed");
        return Task.CompletedTask;
    }
    
    /// <summary>
    /// Clean up consumer groups before tests run.
    /// This ensures tests start with a clean state.
    /// </summary>
    private async Task CleanupConsumerGroups()
    {
        try
        {
            // Stop all consumers
            var kafkaBus = ServiceProvider?.GetRequiredService<IKafkaBus>();
            if (kafkaBus != null)
            {
                foreach (var consumer in kafkaBus.Consumers.All)
                {
                    await consumer.StopAsync();
                }
                await Task.Delay(TimeSpan.FromSeconds(2));
                Console.WriteLine("Consumers stopped successfully");
            }

            // Delete consumer groups from Kafka
            await DeleteConsumerGroupsFromKafka();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Warning: Could not cleanup consumer groups: {ex.Message}");
        }
    }
    
    /// <summary>
    /// Delete the test consumer group from Kafka broker
    /// </summary>
    private async Task DeleteConsumerGroupsFromKafka()
    {
        try
        {
            var kafkaConfig = Configuration.GetSection("KafkaBrokerConfiguration");
            var bootstrapServers = kafkaConfig.GetSection("BootstrapServers").Get<string[]>();
            
            var adminConfig = new AdminClientConfig
            {
                BootstrapServers = string.Join(",", bootstrapServers)
            };

            // Add credentials if they exist (for non-local environments)
            var credentials = kafkaConfig.GetSection("Credentials");
            if (credentials.Exists() && !string.IsNullOrEmpty(credentials["Username"]))
            {
                adminConfig.SecurityProtocol = SecurityProtocol.SaslSsl;
                adminConfig.SaslMechanism = SaslMechanism.Plain;
                adminConfig.SaslUsername = credentials["Username"];
                adminConfig.SaslPassword = credentials["Password"];
            }

            using var adminClient = new AdminClientBuilder(adminConfig).Build();
            
            // Delete the consumer group
            var groupsToDelete = new[] { TestConstants.CONSUMER_GROUP };
            await adminClient.DeleteGroupsAsync(groupsToDelete);
            
            Console.WriteLine($"Deleted consumer groups: {string.Join(", ", groupsToDelete)}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Could not delete consumer groups: {ex.Message}");
        }
    }

    /// <summary>
    /// Runs once after all tests in the test class.
    /// Cleans up resources and disposes the service provider.
    /// </summary>
    [OneTimeTearDown]
    public async Task OneTimeTearDown()
    {
        await CleanupConsumerGroups();
        
        if (ServiceProvider is IDisposable disposable)
        {
            disposable.Dispose();
        }
        
        Console.WriteLine("Journey Framework cleanup completed");
    }
}
```

**Key Methods:**

1. **OneTimeSetUp**: Runs once before all tests - initializes Journey Framework
2. **CleanupConsumerGroups**: Ensures clean state by removing old consumer groups
3. **OneTimeTearDown**: Runs once after all tests - cleans up resources

