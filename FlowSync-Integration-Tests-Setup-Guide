namespace YourService.IntegrationTests.Models;

public class KafkaBrokerConfiguration
{
    public string[] BootstrapServers { get; set; } = Array.Empty<string>();
    public KafkaCredentials Credentials { get; set; } = new();
    
    public bool HasCredentials => 
        !string.IsNullOrEmpty(Credentials?.Username) && 
        !string.IsNullOrEmpty(Credentials?.Password);
}

public class KafkaCredentials
{
    public string Username { get; set; } = string.Empty;
    public string Password { get; set; } = string.Empty;
    public string Mechanism { get; set; } = "plain";
    public string SecurityProtocol { get; set; } = "SaslSsl";
    public string TlsEnabled { get; set; } = "true";
}
