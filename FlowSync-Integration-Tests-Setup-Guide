### Create Kafka Helper for Cleanup

**Create `Helpers/KafkaHelper.cs`:**

```csharp
using Confluent.Kafka;
using Confluent.Kafka.Admin;
using KafkaFlow;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using YourService.IntegrationTests.Constants;
using YourService.IntegrationTests.Models;

namespace YourService.IntegrationTests.Helpers;

public static class KafkaHelper
{
    /// <summary>
    /// Stops all consumers and deletes the consumer group from Kafka.
    /// This prevents test interference and ensures clean state between test runs.
    /// </summary>
    public static async Task DeleteConsumerGroupAsync(
        IServiceProvider provider, 
        IConfiguration configuration)
    {
        // Step 1: Stop all KafkaFlow consumers
        var kafkaBus = provider.GetRequiredService<IKafkaBus>();
        foreach (var messageConsumer in kafkaBus.Consumers.All)
        {
            await messageConsumer.StopAsync();
        }
        
        // Wait for consumers to fully stop
        await Task.Delay(TimeSpan.FromSeconds(2));
        
        // Step 2: Get Kafka broker configuration
        var kafkaBrokerConfig = configuration
            .GetSection("KafkaBrokerConfiguration")
            .Get<KafkaBrokerConfiguration>();
        
        // Step 3: Configure admin client with security settings
        var adminClientConfig = new AdminClientConfig
        {
            BootstrapServers = string.Join(",", kafkaBrokerConfig.BootstrapServers),
        };
        
        // Set security protocol if configured
        if (Enum.TryParse<SecurityProtocol>(
            kafkaBrokerConfig.Credentials.SecurityProtocol, 
            true, 
            out var securityProtocol))
        {
            adminClientConfig.SecurityProtocol = securityProtocol;
        }
        
        // Set SASL credentials if available
        if (kafkaBrokerConfig.HasCredentials)
        {
            adminClientConfig.SaslUsername = kafkaBrokerConfig.Credentials.Username;
            adminClientConfig.SaslPassword = kafkaBrokerConfig.Credentials.Password;
            
            if (Enum.TryParse<SaslMechanism>(
                kafkaBrokerConfig.Credentials.Mechanism, 
                true, 
                out var saslMechanism))
            {
                adminClientConfig.SaslMechanism = saslMechanism;
            }
        }
        
        // Step 4: Delete the consumer group
        using var adminClient = new AdminClientBuilder(adminClientConfig).Build();
        
        try
        {
            await kafkaBus.StopAsync();
            
            await adminClient.DeleteGroupsAsync(new List<string>
            {
                TestConstants.CONSUMER_GROUP
            });
            
            Console.WriteLine($"Deleted consumer group: {TestConstants.CONSUMER_GROUP}");
        }
        catch (DeleteGroupsException ex)
        {
            // Ignore if group doesn't exist
            if (ex.Message.Contains("The group id does not exist"))
            {
                Console.WriteLine($"Consumer group {TestConstants.CONSUMER_GROUP} does not exist");
                return;
            }
            
            Console.WriteLine($"Error deleting consumer group: {ex.Message}");
            throw;
        }
    }
}
```

**Why Consumer Group Cleanup is Critical:**
- Prevents offset commit conflicts between test runs
- Ensures tests start with clean state
- Avoids "stuck" consumer groups that can cause test failures
- Required for idempotent test execution

