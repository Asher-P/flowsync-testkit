## Step 5: Setup IoC Helper

Create `Extensions/IoCHelper.cs` to initialize the dependency injection container and configure Journey Framework:

```csharp
using Journey.Kafka.Configurations;
using Journey.Kafka.Extensions;
using Journey.Kafka.Serializers;
using Journey.Orchestration.Configurations;
using Journey.Orchestration.Entities.Interfaces;
using Journey.Orchestration.Factories;
using Journey.Orchestration.Host;
using KafkaFlow.Serializer;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Steeltoe.Extensions.Configuration.Placeholder;
using YourService.IntegrationTests.Constants;
using YourService.IntegrationTests.Models;

namespace YourService.IntegrationTests.Extensions;

public static class IoCHelper
{
    public static (ServiceProvider, IConfigurationRoot) InitServiceProvider()
    {
        var services = new ServiceCollection();

        // Build configuration with placeholder support
        var configuration = new ConfigurationBuilder()
            .AddJsonFile("appsettings.json", optional: false, reloadOnChange: true)
            .AddEnvironmentVariables()
            .AddPlaceholderResolver()  // Enables ${...} placeholder resolution
            .Build();

        // Register core services
        services.AddSingleton<IConfiguration>(configuration);
        services.AddLogging();
        
        // Register Journey Framework
        services.AddJourneyOrchestration();
        services.ConfigureKafkaJourney(configuration);
        
        var serviceProvider = services.BuildServiceProvider();
        return (serviceProvider, configuration);
    }
    
    private static IServiceCollection ConfigureKafkaJourney(
        this IServiceCollection services,
        IConfigurationRoot configuration)
    {
        services.AddKafkaJourney(builder =>
        {
            // Get Kafka configuration
            var kafkaBrokerConfig = configuration
                .GetSection("KafkaBrokerConfiguration")
                .Get<KafkaBrokerConfiguration>();

            // Configure broker connection
            var kafkaConfigurationBuilder = builder.ConfigureBroker(brokerBuilder =>
            {
                brokerBuilder
                    .WithBootstrapServers(kafkaBrokerConfig.BootstrapServers)
                    .WithCredentials(kafkaBrokerConfig.Credentials);
            });

            // ========================================
            // CONFIGURE CONSUMERS (Output Topics)
            // ========================================
            // Add consumers for each output topic you want to test
            
            kafkaConfigurationBuilder.AddConsumer(consumerBuilder =>
            {
                consumerBuilder
                    .AddTopic(TestConstants.OUTPUT_TOPIC_1)  // Topic to consume from
                    .AddConsumerGroup(TestConstants.CONSUMER_GROUP)
                    .AddConsumingSerializer(new JsonCoreSerializer())  // or KafkaUTF8Serializer
                    .AddConsumingType(typeof(YourOutputDto))  // DTO type to deserialize
                    .SetWorkersCount(1)
                    .SetBufferSize(10);
            });
            
            // Add more consumers for additional output topics
            kafkaConfigurationBuilder.AddConsumer(consumerBuilder =>
            {
                consumerBuilder
                    .AddTopic(TestConstants.OUTPUT_TOPIC_2)
                    .AddConsumerGroup(TestConstants.CONSUMER_GROUP)
                    .AddConsumingSerializer(new JsonCoreSerializer())
                    .AddConsumingType(typeof(AnotherOutputDto))
                    .SetWorkersCount(1)
                    .SetBufferSize(10);
            });

            // ========================================
            // CONFIGURE PRODUCERS (Input Topics)
            // ========================================
            // Add producers for each input topic you want to produce to
            
            kafkaConfigurationBuilder.AddProducer(producerBuilder =>
            {
                producerBuilder
                    .AddProducerTopic(TestConstants.INPUT_TOPIC)  // Topic to produce to
                    .AddProducerSerializer(new JsonCoreSerializer());
            });
        });
        
        return services;
    }
    
    /// <summary>
    /// Helper method to create a Journey Step for testing
    /// </summary>
    public static async Task<IJourneyStep> CreateJourneyStep(
        this IServiceProvider serviceProvider, 
        string outputTopic,
        int timeoutSeconds = 30,
        int expectedMessageCount = 1)
    {
        var journeyFactory = serviceProvider.GetRequiredService<IJourneyFactory>();

        return await journeyFactory.CreateJourneyStepAsync(new JourneyConfiguration
        {
            ProduceTo = TestConstants.INPUT_TOPIC,
            ConsumeFrom = new[] { outputTopic },
            ConsumingOptions = new ConsumingOptionsConfiguration
            {
                TimeOut = TimeSpan.FromSeconds(timeoutSeconds),
                MsgReceivedCount = expectedMessageCount,
            }
        });
    }
}
```

**Key Configuration Points:**

1. **Consumers**: Configure for topics your service produces to (output topics)
2. **Producers**: Configure for topics your service consumes from (input topics)
3. **Serializers**: Use `JsonCoreSerializer` for JSON or `KafkaUTF8Serializer` for UTF-8 strings
4. **Consumer Group**: Use a unique group name for your tests to avoid conflicts

**Customization Required:**
- Replace `TestConstants.OUTPUT_TOPIC_1`, `TestConstants.INPUT_TOPIC` with your actual topic names
- Replace `YourOutputDto`, `AnotherOutputDto` with your actual DTO types
- Adjust serializers based on your message format

**Note on Namespaces:**
- `Journey.Orchestration.*` namespaces are the new naming (previously `journey.*`)
- If you're using an older version of Journey.Kafka, you may still see `journey.*` namespaces

